{
  "name": "agent-rules-init-monorepo",
  "private": true,
  "workspaces": [
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:pack": "npm run test:pack --workspace packages/cli",
    "test:quality": "npm run test:quality --workspace packages/cli",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "check": "npm run typecheck && npm run lint && npm test && npm run test:quality && npm run build && npm run test:pack"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
