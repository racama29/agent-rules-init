{
  "name": "agent-rules-init",
  "version": "0.8.1",
  "description": "Generates CLAUDE.md, AGENTS.md, copilot-instructions.md and prompt files from what your repo actually is.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-rules-init": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/racama29/agent-rules-init.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/racama29/agent-rules-init#readme",
  "bugs": {
    "url": "https://github.com/racama29/agent-rules-init/issues"
  },
  "keywords": [
    "cli",
    "claude",
    "claude-code",
    "codex",
    "copilot",
    "ai-agents",
    "agent-rules"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:pack": "node scripts/smoke-package.mjs && node scripts/check-package-size.mjs",
    "test:hardening": "vitest run test/hardening.test.ts test/quality-matrix.test.ts test/writer.test.ts test/scanner.test.ts",
    "test:quality": "vitest run test/corpus.test.ts test/quality-matrix.test.ts test/ecosystem-corpus.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test scripts",
    "check": "npm run typecheck && npm run lint && npm test && npm run build && npm run test:pack",
    "test:enrich": "npm run build && node scripts/smoke-enrichment.mjs",
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "prepublishOnly": "npm run build && npm run test:pack"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.7"
  }
}
